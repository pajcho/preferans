# Supabase (free tier). Kreiraj projekat na https://supabase.com → Project Settings → API.
# Anon key je javni "publishable" kljuc — bezbedan u browseru jer ga stiti RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Lokalni razvoj: pokreni `pnpm sb:start` pa u .env.local upiši vrednosti iz `supabase status`:
# VITE_SUPABASE_URL=http://127.0.0.1:56321
# VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
