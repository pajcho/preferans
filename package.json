{
  "name": "prefa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "description": "Prefa - online preferans u troje, mobile-first (GitHub Pages + Supabase)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && pnpm run postbuild",
    "postbuild": "cp dist/index.html dist/404.html && touch dist/.nojekyll",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "engine:sync": "sh scripts/sync-shared.sh",
    "sb:start": "pnpm engine:sync && supabase start",
    "sb:stop": "supabase stop",
    "sb:status": "supabase status",
    "sb:reset": "supabase db reset",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "clsx": "^2.1.1",
    "nanoid": "^5.1.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
