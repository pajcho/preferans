{
  "name": "prefa",
  "version": "0.1.0",
  "private": true,
  "description": "Prefa - online preferans u troje, mobile-first (GitHub Pages + Cloudflare Workers)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && pnpm run postbuild",
    "postbuild": "cp dist/index.html dist/404.html && touch dist/.nojekyll",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:workers": "vitest run -c workers/vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc -p workers/tsconfig.json",
    "cf:dev": "sh workers/scripts/ensure-dev-vars.sh && wrangler d1 migrations apply prefa --local -c workers/wrangler.jsonc && wrangler dev -c workers/wrangler.jsonc",
    "cf:types": "wrangler types -c workers/wrangler.jsonc workers/worker-configuration.d.ts",
    "cf:seed": "node workers/seed/generate-seed.mjs > workers/seed/generated-seed.sql && wrangler d1 execute prefa --local -c workers/wrangler.jsonc --file workers/seed/generated-seed.sql",
    "cf:demo-game": "node --experimental-strip-types workers/seed/play-demo-game.mjs",
    "e2e": "playwright test",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "nanoid": "^5.1.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint",
      "oxfmt"
    ],
    "*.{json,jsonc,css,html}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
